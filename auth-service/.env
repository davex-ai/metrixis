# --- Server ---
PORT=4000
APP_URL=http://localhost:5173

# --- Mongo (trustlyx user/session store) ---
MONGO_URI=mongodb://localhost:27017/metrixis

# --- Redis (rate limiting / lockout tracking) ---
REDIS_URL=redis://localhost:6379

# --- JWT secrets ---
# IMPORTANT: JWT_SECRET must be shared with the Python backend (via its own env var)
# so it can verify tokens issued here without calling back to this service.
JWT_SECRET=change-me-to-a-long-random-string
REFRESH_SECRET=change-me-to-a-different-long-random-string

# --- Email (account verification only — no magic-link login) ---
# Gmail sending activates automatically once both vars below are set —
# no NODE_ENV flag needed. Leave GMAIL_USER blank to just log emails to
# the console instead (useful for local testing without real email).
# Use a Gmail App Password, not your regular password:
# https://myaccount.google.com/apppasswords (requires 2-Step Verification enabled)
GMAIL_USER=omotoyedave4@gmail.com
GMAIL_APP_PASSWORD=fmbn ynnc cxpu bwyt

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
