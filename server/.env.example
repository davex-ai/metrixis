# Postgres connection string
DATABASE_URL=postgres://user:password@localhost:5432/metrixis

# Set to "false" only for local Postgres without SSL
PGSSL=true

# Long random string — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string

# Frontend origin (for CORS + cookie sharing)
DASHBOARD_URL=https://metrixis.vercel.app

NODE_ENV=development
PORT=4000
